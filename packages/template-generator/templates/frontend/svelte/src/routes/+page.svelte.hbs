			<p class="text-muted-foreground mb-4 text-sm">
				Launch a sample AbacatePay checkout without requiring sign-in.
			</p>
			<button class="rounded-md border px-4 py-2 text-sm font-medium" on:click={openCheckout}>
				Open Checkout
			</button>
		</section>
		{{/if}}
